---
import { Icon } from "astro-icon/components";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import { getFileDirFromPath, getPostUrl } from "@utils/url";
import { postConfig } from "@/config";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import ImageWrapper from "@components/common/imageWrapper.astro";
import PostMetadata from "./postMeta.astro";


interface Props {
    class?: string;
    entry: CollectionEntry<"posts">;
    style?: string;
}

const className = Astro.props.class;

const { entry, style } = Astro.props;

const url = getPostUrl(entry);

const {
    title,
    published,
    updated,
    description,
    cover,
    tags,
    category,
    pinned,
} = entry.data;

const hasCover = cover !== undefined && cover !== null && cover !== "";

const coverSide = postConfig.card.cover.side;
const isCoverOnRight = coverSide === "right";
const coverWidth = postConfig.card.cover.width;
const coverMargin = "12px";
const coverGap = "12px";
const showContentOnCover = postConfig.card.cover.showContent;
const titleSize = postConfig.card.titleSize;

const { remarkPluginFrontmatter } = await render(entry);

// derive image base path from the real file path to preserve directory casing
const imageBaseDir = getFileDirFromPath(entry.filePath || "");

const defaultCoverGradient = "linear-gradient(135deg, color-mix(in oklch, oklch(from var(--primary) l c calc(h - 30)) 51%, transparent) 0%, color-mix(in oklch, var(--primary) 51%, transparent) 50%, color-mix(in oklch, oklch(from var(--primary) l c calc(h + 30)) 51%, transparent) 100%)";
---

<div class:list={["card-base flex flex-col-reverse @min-[768px]:flex-col w-full rounded-(--radius-large) overflow-hidden relative @container", className]} style={style}>
    <div class:list={["pl-6 @min-[768px]:pl-9 pr-6 @min-[768px]:pr-2 pt-6 @min-[768px]:pt-7 pb-6 relative", 
        {"w-full @min-[768px]:w-[calc(100%-var(--coverWidth)-var(--coverGap))]": isCoverOnRight,
         "ml-0 @min-[768px]:ml-[calc(var(--coverWidth)+var(--coverGap))]": !isCoverOnRight}
    ]}>
        <a href={url}
            class:list={["transition group w-full block font-bold mb-3 text-90 hover:text-(--primary) dark:hover:text-(--primary) active:text-(--title-active) dark:active:text-(--title-active) before:w-1 before:h-5 before:rounded-md before:bg-(--primary) before:absolute before:top-[35px] before:left-[18px] before:hidden @min-[768px]:before:block",
                titleSize
            ]}
        >
            {pinned && <Icon name="mdi:pin" class="inline text-(--primary) text-2xl mr-2 -translate-y-0.5"></Icon>}
            {title}
        </a>
        <!-- metadata -->
        <PostMetadata published={published} updated={updated} tags={tags} category={category || undefined} hideTagsForMobile={true} hideUpdateDate={true} postUrl={url} className="mb-4"></PostMetadata>
        <!-- description -->
        <div class:list={["transition text-75 mb-3.5 pr-4", {"line-clamp-2 @min-[768px]:line-clamp-1": !description}]}>
            { description || remarkPluginFrontmatter.excerpt }
        </div>
        <!-- word count and read time  -->
        <div class="text-sm text-black/30 dark:text-white/30 flex gap-4 transition">
            <div>
                {remarkPluginFrontmatter.words} {" " + i18n(remarkPluginFrontmatter.words === 1 ? I18nKey.wordCount : I18nKey.wordsCount)}
            </div>
            <div>|</div>
            <div>
                {remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}
            </div>
        </div>
    </div>

    <a href={url} aria-label={title} class:list={["group",
            "max-h-[20vh] h-[20vh] @min-[768px]:max-h-none @min-[768px]:h-auto mx-4 mt-4 -mb-2 @min-[768px]:mb-0 @min-[768px]:mx-0 @min-[768px]:mt-0",
            "@min-[768px]:w-(--coverWidth) relative @min-[768px]:absolute @min-[768px]:top-(--coverMargin) @min-[768px]:bottom-(--coverMargin) rounded-xl overflow-hidden active:scale-95",
            {"@min-[768px]:right-(--coverMargin)": isCoverOnRight, "@min-[768px]:left-(--coverMargin)": !isCoverOnRight}
        ]}
    >
        <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
        <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
            <Icon name="material-symbols:chevron-right-rounded"
                class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl">
            </Icon>
        </div>
        {hasCover ? (
            <ImageWrapper src={cover} basePath={imageBaseDir} alt="Cover Image of the Post"
                class="w-full h-full">
            </ImageWrapper>
        ) : (
            <div class="w-full h-full flex items-center justify-center p-4 @min-[768px]:p-6"
                style={`background: ${defaultCoverGradient}`}>
                {entry.data.encrypted ? (
                    <Icon name="mdi:lock" class="text-5xl text-white/81" />
                ) : showContentOnCover ? (
                    <div class="flex flex-col gap-1 w-full">
                        <span class="text-white/81 text-xs font-medium tracking-wide uppercase">
                            {title}
                        </span>
                        <div class="flex flex-wrap gap-1.5 mt-0.5">
                            {tags && tags.length > 0 ? tags.map((tag) => (
                                <span class="px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white/81 bg-white/9 rounded-md">
                                    {tag}
                                </span>
                            )) : (
                                <span class="px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white/63 bg-white/6 rounded-md">
                                    No Tags
                                </span>
                            )}
                        </div>
                        {remarkPluginFrontmatter.excerpt && (
                            <p class="text-white/63 text-sm leading-relaxed line-clamp-3">
                                {remarkPluginFrontmatter.excerpt}
                            </p>
                        )}
                    </div>
                ) : null}
            </div>
        )}
    </a>
</div>

<style define:vars={{coverWidth, coverMargin, coverGap}}>
</style>